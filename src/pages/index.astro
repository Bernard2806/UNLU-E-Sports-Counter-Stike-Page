---
import "../styles/global.css";

const serverIp = "190.106.0.25:27015";
const serverName = "UNLu E-Sports | CS 1.6";
const serverQuery = "https://api.gamemonitoring.net/server/190.106.0.25:27015";
const serverRules = "https://www.gametracker.com/server_info/190.106.0.25:27015/";
const serverConnect = `steam://connect/${serverIp}`;
const mapRotation = ["de_dust2", "de_inferno", "de_nuke", "cs_office", "de_train", "fy_snow"];
const mods = ["AMX Mod X", "Anti-Cheat", "VIP slots", "Friendly fire off", "FastDL"];
const updates = [
  "Inscripciones abiertas para el torneo interno de mayo.",
  "Nueva rotacion nocturna con mapas clasicos.",
  "Reclutamos casters y admins voluntarios.",
];
const storeItems = [
  {
    id: "vip-30",
    name: "VIP 30 dias",
    desc: "Slot reservado, tag VIP y prioridad de cola.",
    price: 3500,
    priceLabel: "ARS 3500",
  },
  {
    id: "skin-pack",
    name: "Skin Pack Retro",
    desc: "Pack cosmetico con sprays y modelos clasicos.",
    price: 2200,
    priceLabel: "ARS 2200",
  },
  {
    id: "clan-support",
    name: "Clan Support",
    desc: "Banner del clan en el server por 30 dias.",
    price: 5000,
    priceLabel: "ARS 5000",
  },
  {
    id: "vip-90",
    name: "VIP 90 dias",
    desc: "Beneficios VIP + acceso a pruebas privadas.",
    price: 9000,
    priceLabel: "ARS 9000",
  },
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Servidor Counter-Strike 1.6 UNLu E-Sports. Info del server, IP, estado y clan."
    />
    <title>UNLu E-Sports CS 1.6 | Clan</title>
  </head>
  <body>
    <div class="max-w-6xl mx-auto mt-4 px-2">
      <!-- HEADER BANNER -->
      <header class="clan-header">
        <img src="/images/cs_header.png" alt="UNLu E-Sports Banner" />
      </header>

      <!-- NAVIGATION -->
      <nav class="clan-nav">
        <a href="#">Home</a>
        <a href="#">Guias</a>
        <a href="#">Downloads</a>
        <a href="#">Servers</a>
      </nav>

      <main class="flex flex-col lg:flex-row gap-4 mb-10">
        
        <!-- LEFT SIDEBAR -->
        <aside class="lg:w-1/4 space-y-4">
          <!-- SERVERS -->
          <div class="win-window">
            <header class="win-titlebar">SERVERS</header>
            <div class="win-content text-sm space-y-2 font-mono">
              <div>
                <span class="text-green-500 font-bold">[PUBLICO]</span><br/>
                {serverIp}<br/>
                &lt;co*&gt; CS 1.6 #15
              </div>
            </div>
          </div>
        </aside>

        <!-- CENTER CONTENT -->
        <div class="lg:w-2/4 space-y-4">
          
          <!-- DOWNLOAD BLOCK -->
          <div class="win-window">
            <header class="win-titlebar">Counter-Strike 1.6 download</header>
            <div class="win-content">
              <h2 class="font-bold mb-2 text-lg">Descargar: Counter-Strike 1.6</h2>
              <p class="text-sm mb-4">El Counter-Strike No Steam Full v7. Recordar bajar el parche v23b para jugar Online.</p>
              
              <div class="flex gap-4 items-center bg-[#111] p-4 border border-black shadow-[inset_0_1px_0_rgba(255,255,255,0.1)]">
                <div class="photo-frame w-24 h-24 shrink-0">
                  <img src="/images/cs_icon.png" alt="CS Download" class="w-full h-full object-cover" />
                </div>
                <div class="flex-grow text-center">
                  <a href="#" class="win-button text-lg px-8 py-3 w-full bg-gradient-to-b from-[#4a5560] to-[#1e2327]">
                    <span class="text-green-400 mr-2">⬇</span> DESCARGAR
                  </a>
                  <p class="mt-2 text-xs text-gray-400">Peso: 240MB | Descargas: 9,794,405</p>
                </div>
              </div>
            </div>
          </div>

          <!-- NOTICIAS -->
          <div class="win-window">
            <header class="win-titlebar">Noticias del Clan</header>
            <div class="win-content space-y-3">
              {updates.map((item) => (
                <div class="win-panel p-3 text-sm">
                  <span class="text-green-400 font-bold mr-2">&gt;</span> {item}
                </div>
              ))}
            </div>
          </div>

          <!-- TIENDA / VIP -->
          <div class="win-window">
            <header class="win-titlebar">Tienda VIP</header>
            <div class="win-content">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="store-grid">
                {storeItems.map((item) => (
                  <div class="win-panel p-3 text-sm flex flex-col justify-between h-full">
                    <div>
                      <div class="flex items-center justify-between mb-2">
                        <p class="font-bold text-white">{item.name}</p>
                        <span class="badge glow">{item.priceLabel}</span>
                      </div>
                      <p class="text-gray-400 text-xs mb-3">{item.desc}</p>
                    </div>
                    <button
                      class="win-button w-full"
                      data-action="add"
                      data-id={item.id}
                      data-name={item.name}
                      data-price={item.price}
                    >
                      Agregar
                    </button>
                  </div>
                ))}
              </div>
            </div>
          </div>

        </div>

        <!-- RIGHT SIDEBAR -->
        <aside class="lg:w-1/4 space-y-4">
          <!-- CARRITO Y ACCESO -->
          <div class="win-window">
            <header class="win-titlebar">Area de Jugador</header>
            <div class="win-content space-y-4 text-sm">
              <div>
                <button class="win-button w-full mb-2" id="login-btn">Entrar con Google</button>
                <button class="win-button w-full mb-2" id="logout-btn" hidden>Salir</button>
                <div class="text-xs text-gray-400 flex justify-between" id="auth-status">
                  <span>Estado:</span> <span class="badge blink">offline</span>
                </div>
                <div class="text-xs text-gray-400 flex justify-between mt-1" id="user-label">
                  <span>Usuario:</span> <span class="badge">anon</span>
                </div>
              </div>

              <hr class="border-gray-700" />

              <div>
                <h3 class="font-bold mb-2">Carrito (<span id="cart-count">0</span>)</h3>
                <div class="win-list p-2 text-xs mb-2" id="cart-items" style="min-height: 50px;">
                  <p class="text-gray-500">Sin items.</p>
                </div>
                <div class="flex justify-between items-center mb-3">
                  <span>Total:</span>
                  <span class="badge" id="cart-total">ARS 0</span>
                </div>
                <div class="text-center text-xs mb-2" id="cart-status">
                  <span class="badge blink">logea para comprar</span>
                </div>
                <button class="win-button w-full" id="checkout-btn">Pagar MercadoPago</button>
              </div>
            </div>
          </div>

          <!-- SERVER INFO -->
          <div class="win-window">
            <header class="win-titlebar">Info del Server</header>
            <div class="win-content text-sm space-y-3">
              <div class="win-panel p-2">
                <p class="font-bold mb-1">Conectar</p>
                <input type="text" value={`connect ${serverIp}`} readonly class="win-input text-xs w-full mb-2 text-center" />
                <a href={serverConnect} class="win-button w-full block text-center">Abrir Steam</a>
              </div>
              <div>
                <p class="font-bold mb-1">Mods Activos</p>
                <ul class="text-xs space-y-1 text-gray-400">
                  {mods.map((mod) => (
                    <li>- {mod}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </aside>

      </main>
    </div>
    
    <script>
      window.__SUPABASE_URL__ = import.meta.env.PUBLIC_SUPABASE_URL;
      window.__SUPABASE_ANON_KEY__ = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    </script>
    <script type="module" src="/store.js"></script>
  </body>
</html>
